{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "composite": true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "node"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tale-ui/react": ["../../packages/react/src/index.ts"],
      "@tale-ui/react/*": ["../../packages/react/src/*"],
      "@tale-ui/charts": ["../../packages/charts/src/index.ts"],
      "@tale-ui/charts/*": ["../../packages/charts/src/*"],
      "@tale-ui/utils": ["../../packages/utils/src/index.ts"],
      "@tale-ui/utils/*": ["../../packages/utils/src/*"],
      "@tale-ui/mcp-studio/*": ["../mcp-studio/*"]
    },
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "references": [
    { "path": "../../packages/utils/tsconfig.build.json" },
    { "path": "../../packages/charts/tsconfig.build.json" },
    { "path": "../../packages/react/tsconfig.build.json" }
  ],
  "include": ["src", "vite-plugin-recipe-api.ts", "../mcp-studio/src/preview/preview.tsx"]
}
