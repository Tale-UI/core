{
  "name": "@tale-ui/monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "deduplicate": "pnpm dedupe",
    "build": "lerna run --no-private build",
    "build:css": "node tools/build-css.js",
    "release:css": "node tools/release-css.js",
    "release:css:patch": "node tools/release-css.js --type patch",
    "release:css:minor": "node tools/release-css.js --type minor",
    "release:css:major": "node tools/release-css.js --type major",
    "release:css:dry-run": "node tools/release-css.js --type patch --dry-run",
    "release:version": "lerna version --no-changelog --no-push --no-git-tag-version --no-private",
    "release:build": "lerna run --concurrency 8 --no-private build --skip-nx-cache",
    "playground:dev": "pnpm -C playground/vite-app dev",
    "playground:build": "pnpm -C playground/vite-app build",
    "scale:dev": "pnpm -C playground/scale dev",
    "scale:build": "pnpm -C playground/scale build",
    "storybook": "pnpm -C playground/storybook dev",
    "storybook:build": "pnpm -C playground/storybook build",
    "open:dev-urls": "node -e \"const { exec } = require('node:child_process'); const urls = ['http://localhost:5174', 'http://localhost:5173']; const openCmd = process.platform === 'win32' ? 'start \\\"\\\" ' : process.platform === 'darwin' ? 'open ' : 'xdg-open '; for (const url of urls) exec(openCmd + url);\"",
    "dev:all": "pnpm open:dev-urls && concurrently -k -n storybook,scale,playground \"pnpm storybook\" \"pnpm scale:dev -- --port 5174 --strictPort\" \"pnpm playground:dev -- --port 5173 --strictPort\"",
    "eslint": "pnpm -r --if-present lint && eslint . --cache --report-unused-disable-directives --max-warnings 0",
    "eslint:ci": "pnpm -r --if-present lint && eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:css": "stylelint \"packages/css/src/**/*.css\" --config .stylelintrc.json",
    "lint:css:fix": "stylelint \"packages/css/src/**/*.css\" --config .stylelintrc.json --fix",
    "stylelint": "stylelint --reportInvalidScopeDisables --reportNeedlessDisables \"**/*.css\" --ignore-path .lintignore",
    "markdownlint": "markdownlint-cli2 \"**/*.{md,mdx}\"",
    "valelint": "pnpm dlx --package @vvago/vale vale sync && git ls-files | grep -E \"\\.(md|mdx)$\" | xargs pnpm dlx --package @vvago/vale vale --filter='.Level==\"error\"'",
    "prettier": "pretty-quick --ignore-path .lintignore --branch master",
    "prettier:all": "prettier --write . --ignore-path .lintignore",
    "start": "pnpm install && pnpm playground:dev",
    "test": "pnpm test:chromium",
    "test:e2e": "cross-env NODE_ENV=production pnpm test:e2e:build && concurrently --success first --kill-others \"pnpm test:e2e:run\" \"pnpm test:e2e:server\"",
    "test:e2e:build": "vite build --config test/e2e/vite.config.mjs",
    "test:e2e:dev": "vite --config test/e2e/vite.config.mjs -l info --port 5173",
    "test:e2e:run": "cross-env VITEST_ENV=chromium vitest run --project e2e",
    "test:e2e:server": "serve test/e2e -p 5173",
    "test:regressions": "cross-env NODE_ENV=production pnpm test:regressions:build && concurrently --success first --kill-others \"pnpm test:regressions:run\" \"pnpm test:regressions:server\"",
    "test:regressions:build": "vite build --config test/regressions/vite.config.mjs",
    "test:regressions:dev": "vite --config test/regressions/vite.config.mjs --port 5173",
    "test:regressions:run": "cross-env VITEST_ENV=chromium vitest run --project regressions",
    "test:regressions:server": "serve test/regressions -p 5173",
    "test:_unit": "cross-env vitest --project @tale-ui/react --project @tale-ui/utils --project @tale-ui/charts --project docs",
    "test:jsdom": "cross-env VITEST_ENV=jsdom pnpm test:_unit",
    "test:jsdom:coverage": "pnpm test:jsdom --coverage",
    "test:chromium": "cross-env VITEST_ENV=chromium pnpm test:_unit",
    "test:chromium:ui": "pnpm test:chromium --browser.headless=false",
    "test:firefox": "cross-env VITEST_ENV=firefox pnpm test:_unit",
    "test:firefox:ui": "pnpm test:firefox --browser.headless=false",
    "test:webkit": "cross-env VITEST_ENV=webkit pnpm test:_unit",
    "test:webkit:ui": "pnpm test:webkit --browser.headless=false",
    "test:browsers": "cross-env VITEST_ENV=all-browsers pnpm test:_unit",
    "typescript": "tsc -b tsconfig.json",
    "audit:bem": "node tools/audit-bem.js",
    "audit:docs": "node tools/audit-docs.js",
    "audit:brand": "node tools/audit-brand.js",
    "audit:components": "node tools/audit-components.js",
    "audit:coverage": "node tools/audit-coverage.js",
    "audit:coverage:check": "node tools/audit-coverage.js --check",
    "registry:generate": "node tools/generate-registry.js",
    "registry:check": "node tools/generate-registry.js --check",
    "cursorrules:generate": "node tools/generate-cursorrules.js",
    "cursorrules:check": "node tools/generate-cursorrules.js --check",
    "audit:snippet-kinds": "node tools/audit-snippet-kinds.js",
    "validate:generated": "node tools/validate-generated.mjs",
    "validate:test": "node tools/run-validator-tests.mjs",
    "golden:validate": "node tools/validate-golden-prompts.mjs",
    "golden:eval": "node tools/eval-golden-prompts.mjs",
    "golden:fix-review": "node tools/eval-fix-review.mjs",
    "validate:imports": "node tools/validate-imports.mjs",
    "generate-docs": "pnpm registry:generate && pnpm cursorrules:generate && pnpm a2ui:generate-docs && pnpm a2ui:generate-catalog",
    "generate-docs:check": "pnpm registry:check && pnpm cursorrules:check && pnpm a2ui:check-docs && pnpm a2ui:check-catalog && pnpm a2ui:audit-docs && pnpm a2ui:validate-examples",
    "a2ui:generate-docs": "node tools/generate-a2ui-catalog-docs.js",
    "a2ui:check-docs": "node tools/generate-a2ui-catalog-docs.js --check",
    "a2ui:validate-examples": "node tools/validate-a2ui-examples.js",
    "a2ui:audit-docs": "node tools/audit-a2ui-catalog-docs.js",
    "a2ui:generate-catalog": "node tools/generate-a2ui-catalog.js",
    "a2ui:check-catalog": "node tools/generate-a2ui-catalog.js --check",
    "a2ui:check-registry-sync": "node tools/audit-a2ui-registry-sync.js",
    "a2ui:golden:validate": "node tools/validate-a2ui-golden-prompts.mjs",
    "a2ui:golden:eval": "node tools/eval-a2ui-golden-prompts.mjs",
    "a2ui:golden:fix-review": "node tools/eval-a2ui-fix-review.mjs",
    "inline-scripts": "tsx ./scripts/inlineScripts.mts",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/css/src/**/*.css": "stylelint --config .stylelintrc.json"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@babel/cli": "^7.28.6",
    "@babel/plugin-transform-react-constant-elements": "7.27.1",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.28.6",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@next/eslint-plugin-next": "^16.1.7",
    "@octokit/rest": "22.0.1",
    "@playwright/test": "1.58.2",
    "@tale-ui/monorepo-tests": "workspace:*",
    "@types/node": "22.18.13",
    "@types/react": "19.2.14",
    "@types/yargs": "17.0.35",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/eslint-plugin": "^1.6.12",
    "@vitest/ui": "4.0.18",
    "chai-dom": "1.12.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "10.3.3",
    "eslint-plugin-testing-library": "^7.16.0",
    "execa": "9.6.1",
    "globals": "^17.4.0",
    "globby": "16.1.0",
    "husky": "^9.1.7",
    "lerna": "9.0.4",
    "lint-staged": "^16.3.0",
    "lucide-react": "^1.7.0",
    "markdownlint-cli2": "0.21.0",
    "prettier": "3.8.1",
    "pretty-quick": "4.2.2",
    "publint": "0.3.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-mdx": "3.1.1",
    "rimraf": "6.1.3",
    "serve": "14.2.5",
    "stylelint": "17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "5.46.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vitest-fail-on-console": "0.10.1",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "pnpm": ">=10",
    "node": ">=22"
  },
  "resolutions": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/types": "^7.29.0",
    "@types/node": "22.18.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
