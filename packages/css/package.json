{
  "name": "@tale-ui/css",
  "version": "2.0.0",
  "description": "CSS foundations, utilities, and themes generated from Tale UI design tokens.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tale-UI/tale-ui.git",
    "directory": "packages/css"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "src/index.css",
  "style": "dist/style.css",
  "exports": {
    ".": "./dist/style.css",
    "./min": "./dist/style.min.css",
    "./src": "./src/index.css",
    "./src/*": "./src/*"
  },
  "scripts": {
    "prebuild": "pnpm --filter @tale-ui/tokens generate:check",
    "build": "node ../../tools/build-css.js",
    "test:package": "pnpm build && publint"
  },
  "files": [
    "src",
    "dist"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  }
}
