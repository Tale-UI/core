{
  "name": "@tale-ui/charts",
  "version": "0.1.5",
  "description": "Recharts-based chart components themed with @tale-ui/css design tokens.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./area-chart": "./src/area-chart/index.ts",
    "./bar-chart": "./src/bar-chart/index.ts",
    "./line-chart": "./src/line-chart/index.ts",
    "./pie-chart": "./src/pie-chart/index.ts",
    "./radar-chart": "./src/radar-chart/index.ts",
    "./radial-bar-chart": "./src/radial-bar-chart/index.ts",
    "./styles": "./src/chart.css"
  },
  "scripts": {
    "prebuild": "rimraf --glob build build-tests \"*.tsbuildinfo\"",
    "build": "node ../../tools/build-package.mjs --copy .npmignore",
    "test": "cross-env VITEST_ENV=jsdom vitest",
    "typescript": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@tale-ui/css": "workspace:*"
  },
  "peerDependencies": {
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19",
    "recharts": ">=2.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "recharts": "^3.8.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tale-UI/tale-ui.git",
    "directory": "packages/charts"
  },
  "license": "MIT"
}
