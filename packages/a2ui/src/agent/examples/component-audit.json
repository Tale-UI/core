              "label": "I agree to the terms and conditions",
              "binding": { "path": "terms" },
              "action": { "name": "toggleTerms", "context": {} }
            }
          }
        },
        {
          "id": "switch-newsletter",
          "component": {
            "Switch": {
              "label": "Subscribe to newsletter",
              "binding": { "path": "newsletter" },
              "action": { "name": "toggleNewsletter", "context": {} }
            }
