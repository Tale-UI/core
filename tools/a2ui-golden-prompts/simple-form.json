            "id": "actions",
            "component": {
              "Row": {
                "justify": "end",
                "children": ["submit"]
              }
            }
          },
          {
            "id": "submit",
            "component": {
              "Button": {
                "label": "Sign in",
                "variant": "primary",
                "action": { "name": "login", "context": {} }
              }
            }
          }
        ]
      }
    ]
