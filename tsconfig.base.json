{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "noErrorTruncation": false,
    "allowJs": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@tale-ui/react": ["./packages/react/src"],
      "@tale-ui/react/styles": ["./packages/react/src/styles.css"],
      "@tale-ui/react/*": ["./packages/react/src/*"],
      "@tale-ui/utils/*": ["./packages/utils/src/*"],
      "@tale-ui/charts": ["./packages/charts/src"],
      "@tale-ui/charts/styles": ["./packages/charts/src/chart.css"],
      "@tale-ui/charts/*": ["./packages/charts/src/*"],
      "@tale-ui/a2ui": ["./packages/a2ui/src"],
      "@tale-ui/a2ui/*": ["./packages/a2ui/src/*"],
      "docs/*": ["./docs/*"]
    }
  },
  "exclude": ["**/.*/", "**/build", "**/build-tests", "**/node_modules", "docs/export"]
}
